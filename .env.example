# Copy this file to `.env.local` and fill in your real values.
# (.env.local is gitignored — it's the right place for secrets.)

# From: Supabase project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional: Server-side Claude key for the Central Location Estimator and other
# Claude-powered mini-apps. This is only used by Supabase Edge Functions
# (set it via `supabase secrets set ANTHROPIC_API_KEY=...`), NOT here in the
# frontend env. Listed here only as a reminder.
# ANTHROPIC_API_KEY=sk-ant-...
