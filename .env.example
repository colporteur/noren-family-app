# Copy this file to `.env.local` and fill in your real values.
# (.env.local is gitignored — it's the right place for secrets.)

# From: Supabase project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Browser-side Google Maps key for the Central Location Estimator's map view.
# This is a SEPARATE key from the server-side geocoding key.
# Lock this one to your domain (HTTP referrer restriction) and Maps JavaScript API only.
# See README → "Setting up the Google Maps API" for steps.
VITE_GOOGLE_MAPS_BROWSER_KEY=YOUR-BROWSER-KEY

# Optional reminders: server-side keys used by Edge Functions. NOT used by
# the frontend — set these via Supabase Dashboard → Project Settings →
# Edge Functions → Manage Secrets (or `supabase secrets set NAME=value`).
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_MAPS_API_KEY=...   (with the Geocoding API enabled)
